{
  "name": "stockmap",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "check": "npm run lint && npm run typecheck && npm run test",
    "deploy": "nuxt build && wrangler deploy",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "migrate": "wrangler d1 migrations apply stockmap --local",
    "migrate:prod": "wrangler d1 migrations apply stockmap --remote",
    "postinstall": "nuxt prepare",
    "preview": "nuxt preview",
    "preview:cf": "nuxt build && wrangler dev",
    "test": "vitest run",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.1.1",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "nuxt": "^4.4.8",
    "reka-ui": "^2.10.1",
    "vue": "^3.5.22",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.9.0",
    "@types/google.maps": "^3.65.2",
    "@types/node": "^26.1.0",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15",
    "vue-tsc": "^3.1.5",
    "wrangler": "^4.107.0"
  }
}
